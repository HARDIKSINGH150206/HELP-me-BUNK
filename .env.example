# Copy this file to .env and fill in your values

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: Connect -> Drivers -> Copy connection string
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=HELPmeBUNK

# Flask Secret Key (generate a random string for production)
SECRET_KEY=your-secret-key-change-this

# Encryption Key for storing passwords (auto-generated if not set)
# Run: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here