# Copy this file to .env and fill in your values
# Generate SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ===== DATABASE =====
# MongoDB Atlas Connection (optional - falls back to JSON storage)
# Get from: https://www.mongodb.com/cloud/atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=HELPmeBUNK

# ===== FLASK SECURITY =====
# Secret key for session encryption (change this for production!)
SECRET_KEY=your-secret-key-change-this-in-production

# Encryption key for storing passwords securely
ENCRYPTION_KEY=your-encryption-key-here

# ===== ACHARYA ERP SETTINGS =====
# ERP login URL (usually https://student.acharyaerptech.in or similar)
ERP_URL=https://student.acharyaerptech.in

# ===== APPLICATION SETTINGS =====
# Flask environment: development or production
FLASK_ENV=development

# Debug mode (set to False in production)
DEBUG=False

# Session timeout in seconds (default: 86400 = 24 hours)
SESSION_TIMEOUT=86400

# ===== AUTO-SYNC DEFAULTS =====
# Default auto-sync interval in hours (1, 2, or 3)
DEFAULT_SYNC_INTERVAL=2

# Whether to enable auto-sync by default
AUTO_SYNC_ENABLED=False

# ===== TARGET ATTENDANCE =====
# Default target percentage for calculations
TARGET_ATTENDANCE=75

# Safety buffer percentage (extra % above target to be safe)
SAFETY_BUFFER=1

# ===== LOGGING =====
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== DEPLOYMENT =====
# Render.com deployment URL (auto-set if deploying on Render)
RENDER_EXTERNAL_URL=http://localhost:10000